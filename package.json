{
  "name": "kotonoha",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build:widget": "npm run build --workspace=packages/sdk && npm run build --workspace=packages/widget && cp packages/widget/dist/kotonoha-chat-widget.js public/embed/kotonoha-chat-widget.js"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "@types/nodemailer": "^7.0.11",
    "cheerio": "^1.2.0",
    "dompurify": "^3.3.1",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.0.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.4",
    "nuxt": "^3.16.0",
    "pdf-parse": "^1.1.1",
    "stripe": "^21.0.1",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.0.5",
    "eslint": "^9.0.0",
    "marked": "^17.0.4",
    "mermaid": "^11.13.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.0"
  }
}
