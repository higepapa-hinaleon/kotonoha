rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ヘルパー関数 =====

    // 認証済みかどうか
    function isAuthenticated() {
      return request.auth != null;
    }

    // ユーザードキュメントを取得
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 指定された組織に所属しているか
    function belongsToOrg(orgId) {
      return isAuthenticated()
        && getUserData().organizationId == orgId;
    }

    // 管理者かどうか（owner, system_admin, または旧 admin）
    function isAdmin() {
      return isAuthenticated()
        && getUserData().role in ['admin', 'system_admin', 'owner'];
    }

    // システム管理者かどうか（owner も含む）
    function isSystemAdmin() {
      return isAuthenticated()
        && getUserData().role in ['system_admin', 'owner'];
    }

    // オーナーかどうか
    function isOwner() {
      return isAuthenticated()
        && getUserData().role == 'owner';
    }

    // 指定されたグループに所属しているか（組織の一致も検証）
    function belongsToGroup(groupId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/userGroupMemberships/$(request.auth.uid + '_' + groupId))
        && get(/databases/$(database)/documents/userGroupMemberships/$(request.auth.uid + '_' + groupId)).data.organizationId == getUserData().organizationId;
    }

    // 指定されたグループの管理者かどうか（組織の一致も検証）
    function isGroupAdmin(groupId) {
      let membership = get(/databases/$(database)/documents/userGroupMemberships/$(request.auth.uid + '_' + groupId)).data;
      return isAuthenticated()
        && membership.role == 'admin'
        && membership.organizationId == getUserData().organizationId;
    }

    // 指定された組織の管理者かどうか（後方互換）
    function isOrgAdmin(orgId) {
      return belongsToOrg(orgId) && isAdmin();
    }

    // ===== organizations =====
    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow write: if isOwner() && belongsToOrg(orgId);
    }

    // ===== groups =====
    match /groups/{groupId} {
      allow read: if isAuthenticated()
        && (belongsToGroup(groupId)
            || (isSystemAdmin() && belongsToOrg(resource.data.organizationId)));
      allow write: if isAuthenticated()
        && isSystemAdmin()
        && belongsToOrg(resource.data.organizationId);
    }

    // ===== userGroupMemberships =====
    match /userGroupMemberships/{membershipId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || (isSystemAdmin() && belongsToOrg(resource.data.organizationId)));
      allow write: if isAuthenticated()
        && isSystemAdmin()
        && belongsToOrg(resource.data.organizationId);
    }

    // ===== users =====
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
            || (isSystemAdmin() && getUserData().organizationId == resource.data.organizationId));
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // システム管理者のみ他ユーザーを更新可能
      allow update: if isAuthenticated()
        && (request.auth.uid == userId
            || (isSystemAdmin() && getUserData().organizationId == resource.data.organizationId));
    }

    // ===== services =====
    match /services/{serviceId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow create: if isAuthenticated()
        && (isGroupAdmin(request.resource.data.groupId) || isSystemAdmin());
      allow update, delete: if isAuthenticated()
        && (isGroupAdmin(resource.data.groupId) || isSystemAdmin());
    }

    // ===== documents =====
    match /documents/{docId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow create: if isAuthenticated()
        && (isGroupAdmin(request.resource.data.groupId) || isSystemAdmin());
      allow update, delete: if isAuthenticated()
        && (isGroupAdmin(resource.data.groupId) || isSystemAdmin());
    }

    // ===== documentChunks =====
    match /documentChunks/{chunkId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== feedbackChunks =====
    match /feedbackChunks/{chunkId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== embeddingCache =====
    match /embeddingCache/{cacheId} {
      allow read, write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== conversations =====
    match /conversations/{convId} {
      // 自分の会話 or 同一組織のシステム管理者 or 同一グループの管理者が閲覧可能
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
            || (isSystemAdmin() && belongsToOrg(resource.data.organizationId))
            || (isGroupAdmin(resource.data.groupId) && belongsToOrg(resource.data.organizationId)));
      // 作成時は groupId の検証を含める
      allow create: if isAuthenticated()
        && (belongsToGroup(request.resource.data.groupId)
            || (isSystemAdmin() && belongsToOrg(request.resource.data.organizationId)));
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
            || (isSystemAdmin() && belongsToOrg(resource.data.organizationId))
            || (isGroupAdmin(resource.data.groupId) && belongsToOrg(resource.data.organizationId)));

      // messages サブコレクション
      match /messages/{msgId} {
        allow read: if isAuthenticated()
          && (get(/databases/$(database)/documents/conversations/$(convId)).data.userId == request.auth.uid
              || (isSystemAdmin() && belongsToOrg(get(/databases/$(database)/documents/conversations/$(convId)).data.organizationId))
              || (isGroupAdmin(get(/databases/$(database)/documents/conversations/$(convId)).data.groupId)
                  && belongsToOrg(get(/databases/$(database)/documents/conversations/$(convId)).data.organizationId)));
        allow write: if false; // サーバーサイドのみ（Admin SDK）
      }
    }

    // ===== improvementRequests =====
    match /improvementRequests/{reqId} {
      allow read: if isAuthenticated()
        && ((isSystemAdmin() && belongsToOrg(resource.data.organizationId))
            || (isGroupAdmin(resource.data.groupId) && belongsToOrg(resource.data.organizationId)));
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== faqs =====
    match /faqs/{faqId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow create: if isAuthenticated()
        && (isGroupAdmin(request.resource.data.groupId) || isSystemAdmin());
      allow update, delete: if isAuthenticated()
        && (isGroupAdmin(resource.data.groupId) || isSystemAdmin());
    }

    // ===== weeklyReports =====
    match /weeklyReports/{reportId} {
      allow read: if isAuthenticated()
        && ((isSystemAdmin() && belongsToOrg(resource.data.organizationId))
            || (isGroupAdmin(resource.data.groupId) && belongsToOrg(resource.data.organizationId)));
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== invitations =====
    match /invitations/{invId} {
      allow read: if isAuthenticated() && isSystemAdmin()
        && belongsToOrg(resource.data.organizationId);
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== contracts =====
    match /contracts/{contractId} {
      allow read: if isAuthenticated() && isSystemAdmin()
        && belongsToOrg(resource.data.organizationId);
      allow write: if false; // サーバーサイドのみ（Admin SDK）
    }

    // ===== settings =====
    match /settings/{settingId} {
      allow read: if isAuthenticated()
        && belongsToOrg(resource.data.organizationId)
        && (belongsToGroup(resource.data.groupId) || isSystemAdmin());
      allow create: if isAuthenticated()
        && (isGroupAdmin(request.resource.data.groupId) || isSystemAdmin());
      allow update, delete: if isAuthenticated()
        && (isGroupAdmin(resource.data.groupId) || isSystemAdmin());
    }
  }
}
